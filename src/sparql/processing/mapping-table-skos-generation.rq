# DESCRIPTION:
# This SPARQL query cross-references agricultural crop cultivation types 
# across systems (AGIS, NAEBI, PSMV). It evaluates the class hierarchy 
# using rdfs:subClassOf paths to infer structural mappings between systems. 
# The outputs are labeled using SKOS terminology (exactMatch, broadMatch, narrowMatch) 
# to describe the relationships, or "disjoint" if no hierarchical link exists.

PREFIX cube: <https://cube.link/>
PREFIX : <https://agriculture.ld.admin.ch/crops/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>

SELECT ?sourceSystem ?sourceCrop ?relation ?targetSystem ?targetCrop
FROM <https://lindas.admin.ch/foag/crops>
WHERE {
  # 1. Iterate over all source crops and combine them with all target systems
  ?setS cube:observation ?obsS .
  ?setT a cube:ObservationSet .
  FILTER(?setS != ?setT)

  ?obsS :cultivationType ?typeS ;
        schema:name ?sourceName .
  FILTER(LANG(?sourceName) = "de")

  # Prepare metadata for the source system
  BIND(REPLACE(STR(?setS), "^.*/crops/([^/]+)/.*$", "$1") AS ?sourceSystem)
  BIND(REPLACE(STR(?setT), "^.*/crops/([^/]+)/.*$", "$1") AS ?targetSystem)
  BIND(CONCAT(?sourceName, " (", REPLACE(STR(?typeS), "^.*/([^/]+)$", "$1"), ")") AS ?sourceCrop)

  # 2. Branching: Match vs. No Match
  {
    # Branch A: A relation exists (Exact, Broad, Narrow)
    ?setT cube:observation ?obsT .
    ?obsT :cultivationType ?typeT ;
          schema:name ?targetName .
    FILTER(LANG(?targetName) = "de")

    BIND(CONCAT(?targetName, " (", REPLACE(STR(?typeT), "^.*/([^/]+)$", "$1"), ")") AS ?targetCrop)

    {
      FILTER(?typeS = ?typeT)
      BIND("exactMatch" AS ?relation)
    }
    UNION
    {
      ?typeS rdfs:subClassOf+ ?typeT .
      FILTER NOT EXISTS { ?setT cube:observation [ :cultivationType ?typeS ] }
      BIND("broadMatch" AS ?relation)
    }
    UNION
    {
      ?typeT rdfs:subClassOf+ ?typeS .
      FILTER NOT EXISTS { ?setT cube:observation [ :cultivationType ?typeS ] }
      BIND("narrowMatch" AS ?relation)
    }
  }
  UNION
  {
    # Branch B: No relation exists (Orphan/Disjoint)
    # Checks via rdfs:subClassOf* (covers identity and subClassOf+) in both directions
    FILTER NOT EXISTS {
      ?setT cube:observation [ :cultivationType ?checkTypeT ] .
      { ?typeS rdfs:subClassOf* ?checkTypeT }
      UNION
      { ?checkTypeT rdfs:subClassOf+ ?typeS }
    }
    BIND("disjoint" AS ?relation)
    BIND("-" AS ?targetCrop)
  }
}
ORDER BY ?sourceSystem ?targetSystem ?relation ?sourceCrop