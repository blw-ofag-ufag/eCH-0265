# ==============================================================================
# PREFIXES
# ==============================================================================

# Local prefixes ---------------------------------------------------------------
@prefix : <https://agriculture.ld.admin.ch/crops/> .
@prefix shape: <https://agriculture.ld.admin.ch/crops/shape/> .
@prefix cultivationtype: <https://agriculture.ld.admin.ch/crops/cultivationtype/> .

# LINDAS prefixes --------------------------------------------------------------
@prefix country: <https://ld.admin.ch/country/> .
@prefix cube: <https://cube.link/> .

# International prefixes -------------------------------------------------------
@prefix adms: <https://www.w3.org/ns/adms#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ghs: <https://agriculture.ld.admin.ch/plant-protection/ghs/> .


# ==============================================================================
# DOCUMENT METADATA
# ------------------------------------------------------------------------------
# The metadata of this document is described as it is rquired by SHACL PLAY!
# Visit https://shacl-play.sparna.fr/play/doc for more on this.
# ==============================================================================

shape: a owl:Ontology ;
    dcterms:creator "Damian Oswald, Lea Stauber, Marc Beringer, Christian Wilda" ;
    dcterms:title "RDF master and reference data about crops"@en ;
    dcterms:created "2026-03-05"^^xsd:date ;
    dcterms:modified "2026-05-04"^^xsd:date ;
    dcterms:description
"""
This project addresses the challenge of fragmented agricultural crop data within the Swiss federal administration, where essential systems all use separate, non-harmonized crop terminologies.
This lack of a "single source of truth" creates significant integration hurdles for digital tools.
In this project, we propose a unified master data system for crops and crop-related objects.
"""@en .

# ==============================================================================
# MAIN ENTITIES
# ==============================================================================

shape:Cultivation a sh:NodeShape ;
    rdfs:label "Cultivation"@en ;
    sh:targetClass :Cultivation ;
    rdfs:comment "Represents a specific, spatio-temporally bound agricultural event. It models a single cultivation cycle of a particular crop on a defined area with start and end dates. For example, 'the 2023 summer wheat cultivation on field X12B3', as distinct from the general concept of 'wheat cultivation'."@en ;
    sh:order 1 ;
    sh:property [
        sh:order 1 ;
        sh:name "Typ"@de,
            "Type"@en ;
        sh:path rdf:type ;
        sh:node shape:CultivationType ;
        sh:minCount 1 ;
    ] .

shape:CultivationType a sh:NodeShape ;
    rdfs:label "Cultivation type"@en ;
    rdfs:comment "This is the core class for the classification of 'cultivations', i.e. for crops. (Partial) translation of other crop types is possible via the hierarchy modelled with this class. For the general hierachy modelling, we use the [RDF schema (RDFS)](https://www.w3.org/TR/rdf-schema/) as well as the [Web Ontology Language (OWL)](https://www.w3.org/TR/owl-guide/)."@en ;
    sh:targetClass :CultivationType ;
    sh:order 2 ;
    sh:property [
        sh:name "Parent cultivation type"@en ;
        sh:order 1 ;
        sh:path rdfs:subClassOf ;
        sh:node shape:CultivationType ;
    ],
    [
        sh:name "Name"@en, "Name"@de ;
        sh:description "Name of this cultivation type."@en ;
        sh:path schema:name ;
    ],
    [
        sh:name "Description"@en, "Beschreibung"@de ;
        sh:description "Textual description of this cultivation type."@en ;
        sh:path schema:description ;
    ] .

# --------------------------------
# AGIS
# --------------------------------

shape:DirectPaymentCrop a sh:NodeShape ;
    rdfs:label "Direct payment crop"@en ;
    rdfs:comment "A classification scheme built for the Swiss direct payment system"@en ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass :AgisObservation ;
    sh:property
        [
            sh:order 1 ;
            a cube:KeyDimension ;
            schema:name "Identifikator"@de ;
            schema:description "Der LNF-Code, auch Kulturcode genannt, ist der allgemein gebräuchliche Identifikator für Direktzahlungskulturen in der Schweiz."@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path schema:identifier ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:ID ;
        ],
        [
            sh:order 2 ;
            schema:name "Bezeichnung"@de, "Name"@en ;
            sh:minCount 1 ;
            sh:path schema:name ;
            sh:nodeKind sh:Literal ;
            sh:datatype rdf:langString ;
        ],
        [
            sh:order 3 ;
            schema:name "Kulturgruppe"@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path :cultivationGroup ;
            sh:node shape:CultivationType ;
        ],
        [
            sh:order 4 ;
            schema:name "Kultur"@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path :cultivationType ;
            sh:node shape:CultivationType
        ],
        [
            sh:order 5 ;
            schema:name "Gültig von"@de ;
            schema:description "Ab welchem Jahr wurde diese Direktzahlungskultur offiziell verwendet?"@de ;
            sh:maxCount 1 ;
            sh:minInclusive "1999"^^xsd:gYear ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:gYear ;
            sh:path schema:validFrom ;
        ],
        [
            sh:order 6 ;
            schema:name "Gültig bis"@de ;
            schema:description "Bis in welchem Jahr wurde diese Direktzahlungskultur offiziell verwendet?"@de ;
            sh:maxCount 1 ;
            sh:path schema:validTo ;
            sh:or (
                [ sh:datatype xsd:gYear ; sh:nodeKind sh:Literal ]
                [ sh:hasValue cube:Undefined ]
            ) ;
        ] .

# -------------------------------
# NAEBI (Suisse Bilanz)
# -------------------------------

shape:NaebiCrop a sh:NodeShape ;
    rdfs:label "Suisse Balance crop"@en ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass :NaebiObservation ;
    sh:property
        [
            sh:order 1 ;
            schema:name "Identifikator"@de,
                "Identifier"@en ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path schema:identifier ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:string ;
        ],
        [
            sh:order 2 ;
            schema:name "Bezeichnung"@de,
                "Name"@en ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path schema:name ;
            sh:nodeKind sh:Literal ;
            sh:datatype rdf:langString ;
        ],
        [
            sh:order 3 ;
            schema:name "Kulturkategorie"@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:string ;
            sh:path :cultivationCategory ;
        ],
        [
            sh:order 4 ;
            schema:name "Kultur-Unterkategorie"@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:string ;
            sh:path :cultivationSubCategory ;
        ],
        [
            sh:order 5 ;
            schema:name "Kultur"@de,
                "Crop"@en ;
            a cube:KeyDimension ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path :cultivationType ;
            sh:node shape:CultivationType ;
        ],
        [
            a cube:MeasureDimension ;
            sh:order 6 ;
            schema:name "N"@de ;
            schema:description "Stickstoff, kg/ha"@de ;
            sh:maxCount 1 ;
            sh:path :N2 ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:decimal ;
            qudt:hasUnit unit:KiloGM-PER-HA ;
            qudt:scaleType qudt:RatioScale ;
        ],
        [
            a cube:MeasureDimension ;
            sh:order 7 ;
            schema:name "P₂O₅"@de ;
            schema:description "Phosphor, kg/dt"@de ;
            sh:maxCount 1 ;
            sh:path :P2O5 ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:decimal ;
            qudt:hasUnit unit:KiloGM-PER-DeciTONNE ;
            qudt:scaleType qudt:RatioScale ;
        ],
        [
            a cube:MeasureDimension ;
            sh:order 8 ;
            schema:name "K₂O"@de ;
            schema:description "Kalium, kg/dt"@de ;
            sh:maxCount 1 ;
            sh:path :K2O ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:decimal ;
            qudt:hasUnit unit:KiloGM-PER-DeciTONNE ;
            qudt:scaleType qudt:RatioScale ;
        ],
        [
            a cube:MeasureDimension ;
            sh:order 9 ;
            schema:name "Mg"@de ;
            schema:description "Magnesium, kg/dt"@de ;
            sh:maxCount 1 ;
            sh:path :Mg ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:decimal ;
            qudt:hasUnit unit:KiloGM-PER-DeciTONNE ;
            qudt:scaleType qudt:RatioScale ;
        ] .

# -----------------------------------
# PSM (Plant Protection / SRPPP)
# -----------------------------------

shape:PlantProtectionCrop a sh:NodeShape ;
    rdfs:label "Plant protection crop"@en ;
    rdfs:comment "Crop of the Swiss registry of plant protection products"@en ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass :PlantProtectionObservation ;
    sh:property
        [
            sh:order 1 ;
            a cube:KeyDimension ;
            schema:name "Identifikator"@de ;
            schema:description "Der Identifikator aus Infofito. Neu ist das eine UUID."@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path schema:identifier ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:ID ;
            sh:pattern "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$" ;
        ],
        [
            sh:order 2 ;
            schema:name "Name"@de ;
            schema:description "Der in Infofito eingetragene Name dieser Kultur"@de ;
            sh:maxCount 4 ;
            sh:minCount 2 ;
            sh:languageIn ( "de" "fr" "it" "en" ) ;
            sh:uniqueLang true ;
            sh:nodeKind sh:Literal ;
            sh:path schema:name ;
        ],
        [
            sh:order 3 ;
            schema:name "Kultur"@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path :cultivationType ;
            sh:node shape:CultivationType ;
        ],
        [
            sh:order 4 ;
            schema:name "Version"@de ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path schema:version ;
            sh:nodeKind sh:Literal ;
            sh:datatype xsd:integer ;
        ],
        [
            sh:order 5 ;
            sh:name "Parent crop"@en ;
            schema:name "Überkultur"@de ;
            sh:path schema:isPartOf ;
            sh:minCount 0 ;
            sh:maxCount 2 ;
            sh:nodeKind sh:IRI ;
            sh:node shape:PlantProtectionCrop ;
        ] .