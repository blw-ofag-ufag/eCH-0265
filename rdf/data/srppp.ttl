# ==============================================================================
# DATASET METADATA
# ==============================================================================

psm: a void:Dataset,
        schema:Dataset,
        dcat:Dataset,
        cube:Cube ;
    dcterms:accrualPeriodicity frequency:ANNUAL ;
    dcterms:creator blw: ;
    schema:contributor blw: ;
    schema:creativeWorkStatus status:Draft ;
    schema:creator blw: ;
    schema:dateCreated "2026-04-16"^^xsd:date ;
    schema:datePublished "2026-04-16"^^xsd:date ;
    schema:description "Kulturen aus dem Pflanzenschutzmittelverzeichnis (PSM) und ihre Identifikatoren."@de,
        "Crops from the Plant Protection Products (PSM) registry and their identifiers."@en ;
    schema:name "PSM-Kulturen"@de,
        "PSM crops"@en ;
    schema:publisher blw: ;
    schema:version "1.0" ;
    schema:workExample <https://ld.admin.ch/application/visualize> ;
    dcat:contactPoint
        [
            a vcard:Organization ;
            vcard:fn "Bundesamt für Landwirtschaft"^^xsd:string ;
            vcard:hasEmail "info@blw.admin.ch"^^xsd:string
        ] ;
    dcat:theme theme:administration,
        theme:agriculture ;
    cube:observationConstraint psm:ObservationConstraint ;
    cube:observationSet psm:ObservationSet .


