@prefix : <https://agriculture.ld.admin.ch/crops/> .
@prefix cultivationtype: <https://agriculture.ld.admin.ch/crops/cultivationtype/> .
@prefix intensity: <https://agriculture.ld.admin.ch/crops/intensity/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix taxon: <https://agriculture.ld.admin.ch/crops/taxon/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# ==============================================================================
# ONTOLOGY METADATA
# ==============================================================================

cultivationtype: a owl:Ontology ;
    dcterms:title "Kulturen-Taxonomie"@de,
        "Crop-Taxonomy"@en .

# ==============================================================================
# SHACL DATA MODEL
# ------------------------------------------------------------------------------
# Run `pyshacl rdf/ontology/cultivationtypes.ttl --format human`
# ==============================================================================

cultivationtype:shape a sh:NodeShape ;
    sh:closed true ;
    sh:targetClass owl:Class, owl:DeprecatedClass ;
    sh:ignoredProperties ( rdf:type ) ;

    # Require AT LEAST ONE of the following relationships:
    # - a parent class (rdfs:subClassOf),
    # - an intersection definition (owl:intersectionOf),
    # - or being part of a parent's unionOf list (^owl:unionOf).
    sh:or (
        [ sh:property [ sh:path rdfs:subClassOf ; sh:minCount 1 ] ]
        [ sh:property [ sh:path owl:intersectionOf ; sh:minCount 1 ] ]
        [ sh:property [ 
            sh:path (
                [ sh:inversePath rdf:first ]
                [ sh:zeroOrMorePath [ sh:inversePath rdf:rest ] ]
                [ sh:inversePath owl:unionOf ]
            ) ; 
            sh:minCount 1 
        ] ]
    ) ;

    # global property definitions
    sh:property
    [
        sh:path schema:name ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "de" "fr" "it" "en" ) ;
        sh:uniqueLang true ;
    ],
    [
        sh:path schema:alternateName ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "de" "fr" "it" "en" ) ;
    ],
    [
        sh:path schema:description ;
        sh:nodeKind sh:Literal ;
        sh:datatype rdf:langString ;
        sh:languageIn ( "de" "fr" "it" "en" ) ;
        sh:uniqueLang true ;
    ],
    [
        sh:path rdfs:subClassOf ;
        sh:nodeKind sh:IRI ;
    ],
    [
        sh:path owl:intersectionOf ;
    ],
    [
        sh:path :botanicalPlant ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ],
    [
        sh:path :managementIntensity ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ],
    [
        sh:path owl:disjointWith ;
        sh:nodeKind sh:IRI ;
        sh:node cultivationtype:shape ;
    ],
    [
        sh:path owl:unionOf ;
    ] .

# ==============================================================================
# Top level groups
# ==============================================================================

# State that all top-level groups are disjoint from each other
[] a owl:AllDisjointClasses ;
   owl:members (
       cultivationtype:1
       cultivationtype:4
       cultivationtype:5
       cultivationtype:6
       cultivationtype:7
       cultivationtype:8
       cultivationtype:9
       cultivationtype:10
       cultivationtype:12
       cultivationtype:13
       cultivationtype:20
       cultivationtype:21
   ) .

cultivationtype:1 a owl:Class ;
    schema:name "Ackerfläche"@de,
        "Terres cultivées"@fr,
        "Superficie coltiva"@it ;
    schema:alternateName "Allg. Feldbau"@de ,
        "Ackerkulturen"@de,
        "Domaine app. grande culture"@fr,
        "Grande culture en général"@fr ;
    schema:description "Umfasst Flächen, die im Rahmen der Fruchtfolge für den Anbau von einjährigen oder temporären Kulturen genutzt werden."@de ;
    rdfs:subClassOf :Cultivation .

cultivationtype:2 a owl:Class ;
    schema:name "Dauerwiesen"@de,
        "Prairies permanentes"@fr,
        "Prati perenni"@it ;
    schema:description "Als Dauerwiese gilt die Fläche, die jährlich mindestens ein Mal zur Futtergewinnung gemäht wird."@de ;
    rdfs:subClassOf cultivationtype:21 .

cultivationtype:3 a owl:Class ;
    schema:name "Dauerweiden"@de,
        "Pâturages permanents"@fr,
        "Pascoli perenni"@it ;
    schema:description "Als Dauerweide gilt die Fläche mit ausschliesslicher Weidenutzung. Verbuschte oder unproduktive Teile einer Weide sind nicht anrechenbar. Anrechenbar sind hingegen die Weideflächen von Waldweiden ausserhalb der Sömmerungsfläche (Art. 19 LBV)."@de ;
    rdfs:subClassOf cultivationtype:21 .

cultivationtype:4 a owl:Class ;
    schema:name "Reben"@de,
        "Vignobles"@fr,
        "Vigna"@it,
        "Vines"@en ;
    schema:alternateName "Weinbau"@de ;
    rdfs:subClassOf :Cultivation ;
    owl:unionOf ( cultivationtype:701 cultivationtype:735 ) .

cultivationtype:5 a owl:Class ;
    schema:name "Obstanlagen"@de,
