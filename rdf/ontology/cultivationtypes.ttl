cultivationtype:21 a owl:Class ;
    schema:name "Dauergrünfläche"@de ;
    schema:alternateName "Dauergrünland"@de ;
    schema:description "Als Dauergrünfläche gilt die mit Gräsern und Kräutern bewachsene Fläche ausserhalb der Sömmerungsflächen. Sie besteht seit mehr als sechs Jahren als Dauerwiese oder als Dauerweide (Art. 19 LBV)."@de ;
    rdfs:subClassOf cultivationtype:114 .

cultivationtype:22 a owl:Class ;
    schema:name "Gemüsebau"@de,
        "Vegetable Production"@en ;
    rdfs:subClassOf :Cultivation ;
    owl:unionOf (
        cultivationtype:23
        cultivationtype:24
    ) .

cultivationtype:23 a owl:Class ;
    schema:name "Gemüsekulturen in geschütztem Anbau"@de ;
    owl:unionOf (
        cultivationtype:801
        cultivationtype:806
    ) .

cultivationtype:24 a owl:Class ;
    schema:name "Freilandgemüse"@de ;
    owl:disjointWith cultivationtype:23 .

# Declare that all specific vegetable cultivation types are mutually exclusive
[] a owl:AllDisjointClasses ;
    owl:members (
        cultivationtype:545
        cultivationtype:546
        cultivationtype:801
        cultivationtype:806
    ) .

