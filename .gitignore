# Mac-specific files
.DS_Store

# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# R Project
*.Rproj

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# Bash scripts for manual LINDAS upload
upload.sh

# ignore processed graph file
graph.ttl

# (very large) geodata .ttl file
rdf/data/geodata.ttl

# Processed RDF data
rdf/processed/*.ttl
!rdf/processed/crop-taxonomy.ttl

# Exclude geopackage files
*.gpkg

# Exclude any notes
notes/
notes.md
notes.qmd

# Environment variables
.env
venv/

# Any results written by analyses etc.
results/

# Test cache
**/__pycache__
test.*
test/warnings_report.json
